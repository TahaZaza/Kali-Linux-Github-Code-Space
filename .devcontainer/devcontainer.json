{
  "name": "Kali Linux Audit Environment",
  "image": "kalilinux/kali-rolling:latest",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ],
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "apt-get update && apt-get install -y kali-linux-default nmap metasploit-framework sqlmap"
}
